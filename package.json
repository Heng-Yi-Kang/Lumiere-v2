{
  "name": "lumiere-v2",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --stream --filter ./frontend --filter ./backend dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:backend": "pnpm --dir backend dev",
    "build:frontend": "pnpm --dir frontend build",
    "build:backend": "pnpm --dir backend build",
    "typecheck:frontend": "pnpm --dir frontend typecheck",
    "typecheck:backend": "pnpm --dir backend typecheck",
    "test:auth": "pnpm --dir backend test:auth",
    "test:llm:backend": "pnpm --dir backend test:llm",
    "test:llm": "pnpm test:llm:backend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "db:reset": "docker compose down -v"
  }
}
