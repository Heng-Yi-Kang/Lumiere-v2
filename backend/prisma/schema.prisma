generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notebook {
  id           String         @id @default(cuid())
  name         String
  courseCode   String
  color        String
  description  String
  conceptCount Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  files        NotebookFile[]

  @@index([courseCode])
}

model NotebookFile {
  id                 String   @id @default(cuid())
  notebookId         String
  name               String
  type               String
  mimeType           String?
  size               String
  uploadDate         String
  status             String   @default("ready")
  summary            String?
  summaryStatus      String   @default("idle")
  summaryError       String?
  summaryGeneratedAt DateTime?
  totalPages         Int?
  sourcePath         String?
  previewFormat      String?
  previewContent     String?
  extractedText      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  notebook    Notebook          @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  chunks      NotebookFileChunk[]
  notes       FileNote[]

  @@index([notebookId])
}

model FileNote {
  id             String       @id @default(cuid())
  notebookFileId String
  title          String
  body           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  notebookFile   NotebookFile @relation(fields: [notebookFileId], references: [id], onDelete: Cascade)

  @@index([notebookFileId])
}

model NotebookFileChunk {
  id              String   @id @default(cuid())
  notebookId      String
  notebookFileId  String
  qdrantPointId   String
  chunkIndex      Int
  tokenCount      Int?
  metadata        Json     @default("{}")
  embeddingModel  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  notebookFile    NotebookFile @relation(fields: [notebookFileId], references: [id], onDelete: Cascade)

  @@unique([notebookFileId, chunkIndex])
  @@unique([qdrantPointId])
  @@index([notebookId])
  @@index([notebookFileId])
}
