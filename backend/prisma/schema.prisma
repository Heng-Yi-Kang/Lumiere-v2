generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notebook {
  id           String         @id @default(cuid())
  name         String
  courseCode   String
  color        String
  description  String
  conceptCount Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  files        NotebookFile[]

  @@index([courseCode])
}

model NotebookFile {
  id          String   @id @default(cuid())
  notebookId  String
  name        String
  type        String
  mimeType    String?
  size        String
  uploadDate  String
  status      String   @default("ready")
  summary     String?
  totalPages  Int?
  sourcePath  String?
  previewFormat String?
  previewContent String?
  extractedText String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  notebook    Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  chunks      NotebookFileChunk[]

  @@index([notebookId])
}

model NotebookFileChunk {
  id              String   @id @default(cuid())
  notebookId      String
  notebookFileId  String
  chunkIndex      Int
  content         String
  tokenCount      Int?
  metadata        Json     @default("{}")
  embedding       Unsupported("vector")
  embeddingModel  String
  embeddingDims   Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  notebookFile    NotebookFile @relation(fields: [notebookFileId], references: [id], onDelete: Cascade)

  @@unique([notebookFileId, chunkIndex])
  @@index([notebookId])
  @@index([notebookFileId])
}
