generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notebook {
  id           String         @id @default(cuid())
  userId       String
  name         String
  courseCode   String
  color        String
  description  String
  conceptCount Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  files        NotebookFile[]
  savedChatReplies NotebookSavedChatReply[]

  @@index([userId])
  @@index([courseCode])
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  passwordHash      String
  role              UserRole           @default(USER)
  disabled          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  notebooks         Notebook[]
  sessions          Session[]
  goals             Goal[]
  studyActivityDays StudyActivityDay[]

  @@index([role])
  @@index([disabled])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Goal {
  id         String   @id @default(cuid())
  userId     String
  text       String
  completed  Boolean  @default(false)
  isPriority Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StudyActivityDay {
  id        String   @id @default(cuid())
  userId    String
  localDate String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate])
  @@index([userId])
  @@index([localDate])
}

enum UserRole {
  ADMIN
  USER
}

enum HlsStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum SavedChatReplyScopeType {
  NOTEBOOK
  FILE
}

model NotebookSavedChatReply {
  id         String                  @id @default(cuid())
  notebookId String
  question   String
  answer     String
  fileId     String?
  fileName   String?
  scopeType  SavedChatReplyScopeType
  citations  Json                    @default("[]")
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([scopeType])
  @@index([fileId])
  @@index([notebookId])
}

model NotebookFile {
  id                 String   @id @default(cuid())
  notebookId         String
  name               String
  type               String
  mimeType           String?
  size               String
  uploadDate         String
  status             String   @default("ready")
  ingestionError     String?
  summary            String?
  summaryStatus      String   @default("idle")
  summaryError       String?
  summaryGeneratedAt DateTime?
  hlsStatus          HlsStatus @default(PENDING)
  hlsMasterPlaylistUrl String?
  hlsGeneratedAt     DateTime?
  videoDurationSeconds Float?
  videoResolution    String?
  totalPages         Int?
  sourcePath         String?
  sourceUrl          String?
  siteName           String?
  previewFormat      String?
  previewContent     String?
  extractedText      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  notebook    Notebook          @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  chunks      NotebookFileChunk[]
  notes       FileNote[]
  ingestionJob NotebookFileIngestionJob?

  @@index([notebookId])
  @@unique([notebookId, sourceUrl])
}

model NotebookFileIngestionJob {
  id             String       @id @default(cuid())
  notebookFileId String       @unique
  status         String       @default("queued")
  attempts       Int          @default(0)
  maxAttempts    Int          @default(3)
  availableAt    DateTime     @default(now())
  lockedAt       DateTime?
  lastError      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  notebookFile   NotebookFile @relation(fields: [notebookFileId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([status, lockedAt])
}

model FileNote {
  id             String       @id @default(cuid())
  notebookFileId String
  title          String
  body           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  notebookFile   NotebookFile @relation(fields: [notebookFileId], references: [id], onDelete: Cascade)

  @@index([notebookFileId])
}

model NotebookFileChunk {
  id              String   @id @default(cuid())
  notebookId      String
  notebookFileId  String
  qdrantPointId   String
  chunkIndex      Int
  tokenCount      Int?
  metadata        Json     @default("{}")
  embeddingModel  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  notebookFile    NotebookFile @relation(fields: [notebookFileId], references: [id], onDelete: Cascade)

  @@unique([notebookFileId, chunkIndex])
  @@unique([qdrantPointId])
  @@index([notebookId])
  @@index([notebookFileId])
}
