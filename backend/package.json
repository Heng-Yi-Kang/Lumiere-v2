    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "dotenv": "^17.2.3",
    "mammoth": "^1.12.0",
    "next": "^15.0.0",
    "officeparser": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
