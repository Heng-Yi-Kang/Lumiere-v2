DATABASE_URL=postgresql://lumiere:lumiere@localhost:5432/lumiere?schema=public

# Set to your deployed frontend origin when the browser calls this backend directly.
FRONTEND_ORIGIN=http://localhost:3000

# Use "none" only when the deployed frontend and backend are on different origins
# and the backend is served over HTTPS.
SESSION_COOKIE_SAME_SITE=lax

# Demo-only escape hatch for plain HTTP deployments. Keep unset in production.
# SESSION_COOKIE_SECURE=false

CHAT_API_BASE_URL=https://openrouter.ai/api/v1
CHAT_API_KEY=
CHAT_MODEL=qwen/qwen3.5-9b
CHAT_API_TIMEOUT_MS=120000

EMBEDDING_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=google/gemini-embedding-2

ENABLE_RERANKING=false
RERANKER_API_BASE=
RERANKER_API_KEY=
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=notebook_chunks

STT_API_BASE=https://openrouter.ai/api/v1
STT_API_KEY=
STT_MODEL=qwen3-asr-1.7b

# multipart is the OpenAI-compatible default. Use json for OpenRouter-style STT endpoints.
STT_REQUEST_FORMAT=multipart

VLM_API_BASE_URL=https://openrouter.ai/api/v1
VLM_API_KEY=
VLM_MODEL=qwen/qwen3-vl-235b-a22b-instruct

VIDEO_SEGMENT_SECONDS=30
VIDEO_MAX_FRAMES=60
YOUTUBE_DOWNLOAD_TIMEOUT_MS=1200000

# Optional. Set this when Puppeteer should use a system Chromium binary.
PUPPETEER_EXECUTABLE_PATH=
