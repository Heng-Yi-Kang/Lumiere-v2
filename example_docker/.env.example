# Public host ports.
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=8080
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=3001

# Internal upstream used by Nginx for /api and /uploads.
BACKEND_UPSTREAM=http://backend:3001

# Optional Vite build-time API base URL.
# Leave empty to keep browser requests same-origin and let Nginx proxy /api.
VITE_API_BASE_URL=

# Backend CORS origin for direct API access. Same-origin browser traffic through
# Nginx does not require CORS, but this is useful if BACKEND_PORT is exposed.
FRONTEND_ORIGIN=http://localhost:8080

# Keep lax for same-origin /api proxying. Use none only when VITE_API_BASE_URL
# points at a different HTTPS backend origin.
SESSION_COOKIE_SAME_SITE=lax

# PostgreSQL. Change these values before public deployment. PostgreSQL is not
# published to the host by default; the backend reaches it on the Compose network.
POSTGRES_DB=lumiere
POSTGRES_USER=lumiere
POSTGRES_PASSWORD=lumiere
DATABASE_URL=postgresql://lumiere:lumiere@postgres:5432/lumiere?schema=public
RUN_PRISMA_MIGRATIONS=true

# Qdrant vector store. Qdrant is not published to the host by default.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=notebook_chunks

# User-uploaded notebook files. This host folder is bind-mounted into the
# backend at NOTEBOOK_UPLOAD_ROOT so uploads remain easy to inspect and back up.
NOTEBOOK_UPLOAD_HOST_DIR=./data/uploads/notebooks

# Web-link scraping uses Puppeteer with the system Chromium installed in the
# backend image. Override this only if you install Chromium/Chrome elsewhere.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# LLM, embeddings, speech, reranking, and vision providers.
# Required for backend startup health: EMBEDDING_API_BASE, EMBEDDING_API_KEY,
# and EMBEDDING_MODEL. The backend also verifies provider connectivity.
CHAT_API_KEY=
CHAT_API_BASE_URL=
CHAT_MODEL=
CHAT_API_TIMEOUT_MS=120000
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen3-vl-embedding-8b
STARTUP_HEALTH_PROVIDER_TIMEOUT_MS=15000
ENABLE_RERANKING=false
RERANKER_API_BASE=
RERANKER_API_KEY=
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
STT_API_BASE=
STT_API_KEY=
STT_MODEL=qwen3-asr-1.7b
# multipart is the OpenAI-compatible default. Use json for OpenRouter-style STT endpoints.
STT_REQUEST_FORMAT=multipart
VLM_API_BASE_URL=
VLM_API_BASE=
VLM_API_KEY=
VLM_MODEL=
VLM_TIMEOUT_MS=45000

# Media and summary processing timeouts in milliseconds. Increase these for
# large uploads or slow provider responses.
AUDIO_COMMAND_TIMEOUT_MS=30000
VIDEO_COMMAND_TIMEOUT_MS=120000
VIDEO_SEGMENT_SECONDS=30
VIDEO_MAX_FRAMES=60
HLS_COMMAND_TIMEOUT_MS=1200000
SUMMARY_REQUEST_TIMEOUT_MS=180000
