# Host port for the Nginx-served frontend.
FRONTEND_PORT=8080

# Internal upstream used by Nginx for /api and /uploads.
# Keep this value when the backend runs on the Docker host at port 3001.
# If the backend is another Compose service, use its service URL, for example:
# BACKEND_UPSTREAM=http://backend:3001
BACKEND_UPSTREAM=http://host.docker.internal:3001

# Optional Vite build-time API base URL.
# Leave empty to keep browser requests same-origin and let Nginx proxy /api.
VITE_API_BASE_URL=
